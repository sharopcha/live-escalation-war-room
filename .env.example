# ── Band API ────────────────────────────────────────────────────────────────
# Register agents at https://app.band.ai/settings/api-keys
# Each agent needs its own key (band_a_...)
BRIDGE_AGENT_KEY=band_a_REPLACE_ME
TRIAGE_AGENT_KEY=band_a_REPLACE_ME
KNOWLEDGE_AGENT_KEY=band_a_REPLACE_ME
COMPLIANCE_AGENT_KEY=band_a_REPLACE_ME

# Agent IDs returned by register_my_agent (used for @mentions)
TRIAGE_AGENT_ID=REPLACE_ME
KNOWLEDGE_AGENT_ID=REPLACE_ME
COMPLIANCE_AGENT_ID=REPLACE_ME
BRIDGE_AGENT_ID=REPLACE_ME

BAND_BASE_URL=https://app.band.ai

# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME          # used by triage + optional knowledge synthesis
FEATHERLESS_API_KEY=REPLACE_ME        # used by compliance agent

TRIAGE_MODEL=gpt-4o-mini
COMPLIANCE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Bridge server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ── Renggo integration ───────────────────────────────────────────────────────
# Renggo's outbound call endpoint (callback path)
RENGGO_OUTBOUND_URL=http://localhost:8000/api/v1/calls/outbound
RENGGO_API_KEY=REPLACE_ME

# In-call resolution timeout (seconds) — after this, bridge switches to callback
IN_CALL_TIMEOUT_S=20
