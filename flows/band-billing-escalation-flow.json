              "id": "t-greet-billing",
              "label": "Billing dispute",
              "conditionType": "prompt",
              "condition": "The caller mentions a billing problem, a duplicate or double charge, an incorrect charge, or wants a refund",
              "targetNodeId": "collect-caller-id"
            },
            {
              "id": "t-greet-other",
              "label": "Other / unclear",
              "conditionType": "default",
              "targetNodeId": "out-of-scope"
            }
